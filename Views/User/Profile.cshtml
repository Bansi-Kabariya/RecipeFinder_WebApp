@model RecipeFinder_WebApp.Models.User
@{
    Layout = "_Layout";
}

<div class="hero-section" style="background: linear-gradient(120deg,#ed6ea0,#ffa64d); padding: 80px 0; color:#fff; border-bottom:5px solid #ffc107; text-align:center;">
    <div class="container">
        <h1 class="display-4 fw-bold">Your <span class="text-warning">Profile</span></h1>
        <p class="lead">Manage your account and preferences.</p>
    </div>
</div>

<div class="container py-5">
    @* Fixed CSS: Using -60px for overlapping effect *@
    <div class="card shadow-sm rounded-3 p-4" style="max-width:900px; margin: 10px auto 5px; position: relative; z-index: 1;">
        <div class="d-flex align-items-center gap-4">
            <div style="width:80px; height:80px; border-radius:50%; background:#ffc107; display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-size:28px;">
                @(Model.FullName?.Length > 0 ? Model.FullName.Substring(0, 1) : "?")
            </div>
            <div>
                <h4 class="fw-bold mb-1">@Model.FullName</h4>
                <div class="text-muted">@Model.Email</div>
                <div class="text-muted small mt-2">Mobile: @Model.MobileNumber &nbsp; Gender: @Model.Gender &nbsp; Address: @Model.Address</div>
            </div>
        </div>
        <hr class="my-3" />
        <div class="mt-3 d-flex gap-3">
            <a asp-controller="User" asp-action="EditProfile" class="btn btn-warning text-dark fw-bold">Edit Profile</a>
            <a asp-controller="Admin" asp-action="Logout" class="btn btn-danger">Logout</a>
        </div>
    </div>
</div>

@if (Context.Request.Path.Value != null && Context.Request.Path.Value.Contains("EditProfile"))
{
    @await Html.PartialAsync("_EditProfileModal", Model)
}