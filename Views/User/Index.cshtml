@{
    ViewData["Title"] = "QuickCook - Home";
}

<style>
    /* 1. Hero Section - EXACT Match to About Page height and style */
    .hero-section {
        background: linear-gradient(rgba(211, 47, 47, 0.8), rgba(211, 47, 47, 0.8)), url('https://images.unsplash.com/photo-1543353071-873f17a7a088?q=80&w=2000&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
        background-attachment: fixed; /* Creates a beautiful parallax scrolling effect */
        color: white;
        padding: 100px 0; /* Slightly more padding for better visual impact */
        text-align: center;
        border-bottom: 5px solid #ffc107;
    }

    /* 2. Categories Section - Clean, no highlight borders */
    .category-card {
        border: 1px solid #e0e0e0; /* Subtle thin border only */
        border-radius: 20px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background: #fff;
        height: 100%;
        padding: 2rem;
    }

        .category-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
            border-color: #ffc107; /* Subtle yellow hint on hover */
        }

    /* Healthy Diet Icon Style */
    .diet-icon {
        width: 70px;
        height: 70px;
        background: #fff9e6;
        color: #ffc107;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2rem;
    }

    .standard-icon {
        width: 70px;
        height: 70px;
        background: #f8f9fa;
        color: #d32f2f;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2rem;
    }

    /* Latest recipes */
    .recipe-card {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid #eee;
        background: #fff;
    }
    .recipe-card .img-wrap { height: 160px; background-size: cover; background-position: center; }
    .recipe-card .card-body { padding: 1rem; }
    .recipe-badge { font-size: 0.75rem; padding: 0.25rem 0.6rem; border-radius: 999px; }
    .view-recipe-btn { background: #ffc107; color: #b42b2b; border-radius: 6px; }
</style>

<div class="hero-section">
    <div class="container">
        <h1 class="display-4 fw-bold">Welcome to <span class="text-warning">QuickCook</span></h1>
        <p class="lead fs-4">Healthy eating starts with the right choices.</p>
        <a href="#explore" class="btn btn-warning fw-bold text-danger px-4 rounded-pill mt-3 shadow-sm">Explore Menu</a>
    </div>
</div>

<div id="explore" class="container py-5 my-5 text-center">
    <div class="mb-5">
        <h2 class="fw-bold">Explore Our <span class="text-danger">Kitchen</span></h2>
        <p class="text-muted">Discover delicious land-picked recipes just for you.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="category-card shadow-sm">
                <div class="diet-icon">
                    <i class="bi bi-apple"></i>
                </div>
                <h4 class="fw-bold">Diet Breakfast</h4>
                <p class="text-muted small">Healthy, green, and nutritious options to fuel your morning.</p>
                <a asp-controller="Recipe" asp-action="Category" asp-route-id="Diet" class="btn btn-outline-warning btn-sm rounded-pill px-4 mt-2 fw-bold text-dark">View Recipes</a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="category-card shadow-sm">
                <div class="standard-icon">
                    <i class="bi bi-fire"></i>
                </div>
                <h4 class="fw-bold">Spicy Special</h4>
                <p class="text-muted small">For those who love a kick of heat in every bite.</p>
                <a asp-controller="Recipe" asp-action="Category" asp-route-id="Spicy" class="btn btn-outline-danger btn-sm rounded-pill px-4 mt-2">View Recipes</a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="category-card shadow-sm">
                <div class="standard-icon" style="color: #0d6efd; background: #f0f7ff;">
                    <i class="bi bi-lightning-charge"></i>
                </div>
                <h4 class="fw-bold" style="color: #0d6efd;">Quick Bites</h4>
                <p class="text-muted small">Delicious meals ready in under 10 minutes.</p>
                <a asp-controller="Recipe" asp-action="Category" asp-route-id="Quick" class="btn btn-outline-primary btn-sm rounded-pill px-4 mt-2">View Recipes</a>
            </div>
        </div>

        <div class="col-md-3">
            <div class="category-card shadow-sm">
                <div class="standard-icon" style="color: #6f42c1; background: #f8f4ff;">
                    <i class="bi bi-cake2"></i>
                </div>
                <h4 class="fw-bold" style="color: #6f42c1;">Desserts</h4>
                <p class="text-muted small">Sweet treats to perfectly end your meal.</p>
                <a asp-controller="Recipe" asp-action="Category" asp-route-id="Desserts" class="btn btn-outline-secondary btn-sm rounded-pill px-4 mt-2">View Recipes</a>
            </div>
        </div>
    </div>
</div>

<!-- Latest Recipes Section -->
<div class="container py-5">
    <div class="text-center mb-4">
        <h3 class="fw-bold">Latest <span class="text-danger">Recipes</span></h3>
        <p class="text-muted">Total Recipes: 8</p>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="recipe-card shadow-sm">
                <div class="img-wrap" style="background-image:url('/images/recipes/1.svg');"></div>
                <div class="card-body">
                    <h5 class="fw-bold mb-1">Bhakhri</h5>
                    <p class="text-muted small mb-2">Traditional Gujarati crispy flatbread made ...</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge recipe-badge bg-warning text-white">Breakfast</span>
                        <a asp-controller="Admin" asp-action="RecipeDetails" asp-route-name="Bhakhri" class="btn btn-sm view-recipe-btn">View Recipe</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="recipe-card shadow-sm">
                <div class="img-wrap" style="background-image:url('/images/recipes/2.svg');"></div>
                <div class="card-body">
                    <h5 class="fw-bold mb-1">Gujarati Thali</h5>
                    <p class="text-muted small mb-2">A wholesome platter of traditional Gujarati ...</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge recipe-badge bg-info text-white">Lunch</span>
                        <a asp-controller="Admin" asp-action="RecipeDetails" asp-route-name="Gujarati Thali" class="btn btn-sm view-recipe-btn">View Recipe</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="recipe-card shadow-sm">
                <div class="img-wrap" style="background-image:url('/images/recipes/3.svg');"></div>
                <div class="card-body">
                    <h5 class="fw-bold mb-1">Pav Bhaji</h5>
                    <p class="text-muted small mb-2">A spicy mashed vegetable curry served with ...</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge recipe-badge bg-warning text-white">Dinner</span>
                        <a asp-controller="Admin" asp-action="RecipeDetails" asp-route-name="Pav Bhaji" class="btn btn-sm view-recipe-btn">View Recipe</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="recipe-card shadow-sm">
                <div class="img-wrap" style="background-image:url('/images/recipes/4.svg');"></div>
                <div class="card-body">
                    <h5 class="fw-bold mb-1">Oreo Cupcake</h5>
                    <p class="text-muted small mb-2">A soft and chocolaty cupcake made with ...</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="badge recipe-badge bg-secondary text-white">Desserts</span>
                        <a asp-controller="Admin" asp-action="RecipeDetails" asp-route-name="Oreo Cupcake" class="btn btn-sm view-recipe-btn">View Recipe</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center">
        <a asp-controller="Recipe" asp-action="Index" class="btn btn-danger rounded-pill px-4 py-2">All Recipes <span class="badge bg-warning text-dark ms-2">8</span></a>
    </div>
</div>

<div class="bg-light py-5 border-top">
    <div class="container text-center">
        <h3 class="fw-bold mb-5">How <span class="text-danger">QuickCook</span> Works</h3>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="text-danger fs-1 mb-2">1</div>
                <h5 class="fw-bold">Check Your Fridge</h5>
                <p class="text-muted small">See what ingredients you have today.</p>
            </div>
            <div class="col-md-4 mb-4">
                <div class="text-danger fs-1 mb-2">2</div>
                <h5 class="fw-bold">Select Category</h5>
                <p class="text-muted small">Pick a collection that fits your mood.</p>
            </div>
            <div class="col-md-4 mb-4">
                <div class="text-danger fs-1 mb-2">3</div>
                <h5 class="fw-bold">Get Cooking!</h5>
                <p class="text-muted small">Follow simple steps to a great meal.</p>
            </div>
        </div>
    </div>
</div>
