<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel - QuickCook</title>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        :root {
            --admin-red: #9e1c22;
            --admin-yellow: #ffc107;
            --bg-gray: #f4f7f6;
        }

        body {
            background-color: var(--bg-gray);
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        /* Sidebar Styling */
        .sidebar {
            height: 100vh;
            width: 240px;
            position: fixed;
            background: var(--admin-red);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
        }

        .sidebar-header {
            padding: 20px;
            color: var(--admin-yellow);
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.1rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .nav-link {
            color: rgba(255,255,255,0.8) !important;
            padding: 12px 20px;
            transition: 0.2s;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 0.95rem;
        }

            .nav-link:hover {
                background: rgba(255,255,255,0.05);
                color: white !important;
            }

            /* The specific Yellow active state from your photo */
            .nav-link.active {
                background: var(--admin-yellow) !important;
                color: #000 !important;
                font-weight: 600;
            }

        .logout-btn {
            margin-top: auto;
            background: rgba(0,0,0,0.2);
            padding: 15px;
            text-align: center;
            color: white;
            text-decoration: none;
            transition: 0.3s;
        }

            .logout-btn:hover {
                background: #7a151a;
                color: white;
            }

        /* Main Content Area */
        .main-content {
            margin-left: 240px;
            min-height: 100vh;
            width: calc(100% - 240px);
        }

        .top-navbar {
            background: white;
            padding: 10px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid #eee;
        }

        .user-pill {
            background: #eef8ff;
            color: #0d6efd;
            border-radius: 8px;
            padding: 5px 15px;
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <div class="sidebar-header">
            <i class="bi bi-shield-check text-warning fs-4"></i> Admin Panel
        </div>
        <nav class="nav flex-column mt-3">
            <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Dashboard" ? "active" : "")" asp-action="Dashboard">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Recipes" ? "active" : "")" asp-action="Recipes">
                <i class="bi bi-book"></i> Recipes
            </a>
            <a class="nav-link" href="#"><i class="bi bi-people"></i> Users</a>
            <a class="nav-link" href="#"><i class="bi bi-tags"></i> Categories</a>
            <a class="nav-link" href="#"><i class="bi bi-chat-dots"></i> Feedback</a>
            <a class="nav-link" href="#"><i class="bi bi-envelope"></i> Contact Messages</a>
            <a class="nav-link" href="#"><i class="bi bi-gear"></i> Settings</a>
            <a class="nav-link" asp-controller="Home" asp-action="Index">
                <i class="bi bi-house-door"></i> Go to User Side
            </a>
        </nav>
        <a asp-action="Logout" class="logout-btn">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>

    <div class="main-content">
        <div class="top-navbar">
            <img src="/images/logo.png" height="35" onerror="this.style.display='none'">
            <div class="d-flex align-items-center gap-4">
                <a href="/" class="user-pill"><i class="bi bi-house"></i> User Side</a>
                <div class="d-flex align-items-center">
                    <div class="text-end me-2">
                        <div class="fw-bold small">Admin</div>
                        <div class="text-muted small" style="font-size: 0.75rem;">Administrator</div>
                    </div>
                    <div class="bg-warning rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width: 35px; height: 35px;">A</div>
                </div>
            </div>
        </div>

        <div class="p-4">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>