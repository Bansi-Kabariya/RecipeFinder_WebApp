<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel - QuickCook</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        :root {
            --quick-red: #d32f2f; /* The deep red from your header */
            --quick-yellow: #ffc107; /* The bright yellow from your buttons */
        }

        body {
            background-color: #f8f9fa;
        }

        .sidebar {
            height: 100vh;
            width: 250px;
            position: fixed;
            background: var(--quick-red);
            padding-top: 20px;
            box-shadow: 2px 0 5px rgba(0,0,0,0.2);
            z-index: 1000;
        }

        .nav-header {
            color: var(--quick-yellow);
            padding: 10px 25px;
            font-weight: bold;
            font-size: 1.5rem;
            margin-bottom: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            text-align: center;
        }

        .sidebar a {
            padding: 12px 25px;
            text-decoration: none;
            display: block;
            color: white !important; /* Forces text to stay white */
            font-weight: 500;
            transition: all 0.3s ease;
            border-left: 4px solid transparent;
        }

            .sidebar a:hover {
                background: rgba(255, 255, 255, 0.15);
                color: var(--quick-yellow) !important;
                border-left: 4px solid var(--quick-yellow);
            }

            /* Use this class for the current active page */
            .sidebar a.active {
                background: rgba(0, 0, 0, 0.1);
                color: var(--quick-yellow) !important;
                border-left: 4px solid var(--quick-yellow);
            }

        .main-content {
            margin-left: 250px; /* Matches sidebar width */
            padding: 40px;
            width: calc(100% - 250px);
        }

        .exit-link {
            position: absolute;
            bottom: 20px;
            width: 100%;
            border-top: 1px solid rgba(255,255,255,0.1);
        }
    </style>
</head>

<body>

    <div class="d-flex">
        <div class="sidebar">
            <div class="nav-header">QuickCook</div>

            <nav class="nav flex-column">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Admin" asp-action="Recipes">
                            <i class="bi bi-journal-album"></i> Recipes
                        </a>
                    </li>
                </ul>
                <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">🏠 Dashboard</a>
                <a class="nav-link" asp-controller="Admin" asp-action="Users">👥 Users</a>
                <a class="nav-link" asp-controller="Admin" asp-action="Recipes">📖 Recipes</a>
                <a class="nav-link" asp-controller="Admin" asp-action="Categories">📂 Categories</a>
                <a class="nav-link" asp-controller="Admin" asp-action="Ingredients">🍎 Ingredients</a>
                <a class="nav-link" asp-controller="Admin" asp-action="Reviews">⭐ Reviews</a>
                <a class="nav-link" asp-controller="Admin" asp-action="Wishlist">❤️ Wishlist</a>
                <a class="nav-link" asp-controller="Admin" asp-action="Contact">📧 Contact</a>
                <a class="nav-link" asp-controller="Admin" asp-action="Save">💾 Saved Recipes</a>
            </nav>

            <div class="exit-link">
                <a class="nav-link text-warning" asp-controller="Home" asp-action="Index">⬅ Exit to Site</a>
            </div>
        </div>

        <div class="main-content">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>