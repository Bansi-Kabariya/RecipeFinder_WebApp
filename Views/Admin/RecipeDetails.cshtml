@model RecipeFinder_WebApp.Models.Recipes
@{
 Layout = "_AdminLayout";
}

<div class="card border-0 shadow-sm rounded-4 p-4">
 <div class="row g-4">
 <div class="col-md-5">
 <img src="@Model.ImageUrl" class="img-fluid rounded-4" alt="@Model.RecipeName" />
 </div>
 <div class="col-md-7">
 <h2 class="fw-bold text-danger">@Model.RecipeName</h2>
 <div class="mb-3">
 <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-3">Category</span>
 <span class="ms-3 text-muted">Cooking Time: @Model.CookingTime mins</span>
 <span class="ms-3 text-muted">Servings: @Model.Servings</span>
 </div>
 <h5 class="fw-bold">Description</h5>
 <p>@Model.Description</p>
 <h5 class="fw-bold">Instructions</h5>
 <pre class="bg-light p-3 rounded">@Model.Instructions</pre>
 </div>
 </div>
</div>