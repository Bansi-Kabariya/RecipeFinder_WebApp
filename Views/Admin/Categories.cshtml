@model IEnumerable<RecipeFinder_WebApp.Models.Categories>
@{
    Layout = "_AdminLayout";
}

<div class="card border-0 shadow-sm rounded-4 p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Manage Categories</h4>
        <button type="button" class="btn btn-warning fw-bold rounded-3 px-4 shadow-sm" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
            <i class="bi bi-plus-lg"></i> Add Category
        </button>
    </div>

    <div class="row g-3">
        @if (Model != null && Model.Any())
        {
            foreach (var cat in Model)
            {
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm text-center p-3 rounded-4 bg-white">
                        <div class="fs-1 mb-2">📁</div>
                        <h6 class="fw-bold text-dark">@cat.CategoriesName</h6>
                        <div class="mt-2 d-flex justify-content-center gap-2">
                            <button class="btn btn-sm btn-light text-primary border"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-light text-danger border"><i class="bi bi-trash"></i></button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">No categories found. Click "Add Category" to create one.</p>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="addCategoryModalLabel">New Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-controller="Admin" asp-action="CreateCategory" method="post">
                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted text-uppercase">Category Name</label>
                        <input type="text" name="CategoriesName" class="form-control rounded-3 border-warning shadow-sm" placeholder="e.g. Italian" required autofocus>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning fw-bold rounded-3 py-2">Save Category</button>
                        <button type="button" class="btn btn-light fw-bold rounded-3 py-2" data-bs-dismiss="modal">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>