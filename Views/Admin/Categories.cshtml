@model IEnumerable<RecipeFinder_WebApp.Models.Categories>
@{
    Layout = "_AdminLayout";
}

<div class="card border-0 shadow-sm rounded-4 p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Manage Categories</h4>
        <div>
            <button class="btn btn-warning fw-bold rounded-3 px-4" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
                + Add Category
            </button>
        </div>
    </div>

    <div class="row g-3">
        @if (Model != null && Model.Any())
        {
            foreach (var cat in Model)
            {
                <div class="col-md-3">
                    <div class="card h-100 border-0 shadow-sm text-center p-3 rounded-4 bg-white">
                        <div class="fs-1 mb-2">📁</div>
                        <h6 class="fw-bold text-dark">@cat.CategoriesName</h6>
                        <div class="mt-2 d-flex justify-content-center gap-2">
                            <button class="btn btn-sm btn-light text-primary border"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-light text-danger border"><i class="bi bi-trash"></i></button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <p class="text-muted">No categories found. Click "Add Category" to create one.</p>
            </div>
        }
    </div>
</div>

<!-- Add Category Modal -->
<div class="modal fade" id="addCategoryModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">Add New Category</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="CreateCategory" asp-controller="Admin" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Category Name *</label>
                        <input type="text" name="CategoriesName" class="form-control rounded-3" placeholder="e.g., Breakfast" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Description</label>
                        <textarea name="Description" class="form-control rounded-3" rows="3" placeholder="Brief description..."></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Icon</label>
                        <div class="d-flex gap-2 mt-2">
                            <label class="btn btn-outline-secondary btn-sm rounded-circle p-2">
                                <input type="radio" name="Icon" value="egg" autocomplete="off" hidden />
                                <i class="bi bi-egg-fried"></i>
                            </label>
                            <label class="btn btn-outline-secondary btn-sm rounded-circle p-2">
                                <input type="radio" name="Icon" value="sun" autocomplete="off" hidden />
                                <i class="bi bi-brightness-high"></i>
                            </label>
                            <label class="btn btn-outline-secondary btn-sm rounded-circle p-2">
                                <input type="radio" name="Icon" value="moon" autocomplete="off" hidden />
                                <i class="bi bi-moon"></i>
                            </label>
                            <label class="btn btn-outline-secondary btn-sm rounded-circle p-2">
                                <input type="radio" name="Icon" value="cupcake" autocomplete="off" hidden />
                                <i class="bi bi-cupcake"></i>
                            </label>
                            <label class="btn btn-outline-secondary btn-sm rounded-circle p-2">
                                <input type="radio" name="Icon" value="leaf" autocomplete="off" hidden />
                                <i class="bi bi-leaf"></i>
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Color</label>
                        <div class="d-flex gap-2 mt-2 align-items-center">
                            <label class="color-swatch rounded" style="width:34px;height:24px;background:#f25f5f;border:2px solid #f25f5f;display:inline-block;cursor:pointer;">
                                <input type="radio" name="Color" value="#f25f5f" hidden />
                            </label>
                            <label class="color-swatch rounded" style="width:34px;height:24px;background:#2ec4b6;display:inline-block;cursor:pointer;">
                                <input type="radio" name="Color" value="#2ec4b6" hidden />
                            </label>
                            <label class="color-swatch rounded" style="width:34px;height:24px;background:#6bd3a7;display:inline-block;cursor:pointer;">
                                <input type="radio" name="Color" value="#6bd3a7" hidden />
                            </label>
                            <label class="color-swatch rounded" style="width:34px;height:24px;background:#ffd166;display:inline-block;cursor:pointer;">
                                <input type="radio" name="Color" value="#ffd166" hidden />
                            </label>
                            <label class="color-swatch rounded" style="width:34px;height:24px;background:#6a4c93;display:inline-block;cursor:pointer;">
                                <input type="radio" name="Color" value="#6a4c93" hidden />
                            </label>
                            <label class="color-swatch rounded" style="width:34px;height:24px;background:#ff7b54;display:inline-block;cursor:pointer;">
                                <input type="radio" name="Color" value="#ff7b54" hidden />
                            </label>
                            <label class="color-swatch rounded" style="width:34px;height:24px;background:#146c94;display:inline-block;cursor:pointer;">
                                <input type="radio" name="Color" value="#146c94" hidden />
                            </label>
                            <label class="color-swatch rounded" style="width:34px;height:24px;background:#b497e7;display:inline-block;cursor:pointer;">
                                <input type="radio" name="Color" value="#b497e7" hidden />
                            </label>
                        </div>
                    </div>

                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-secondary rounded-3" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning fw-bold rounded-3 px-4">+ Add Category</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mt-4">
    <div class="col-md-4">
        <div class="card border rounded-3 p-4 text-center h-100">
            <div class="mb-3"><i class="bi bi-egg-fried fs-2 text-danger"></i></div>
            <h5 class="fw-bold">Breakfast</h5>
            <div class="text-muted">2 recipes</div>
            <div class="mt-3">
                <button class="btn btn-sm btn-outline-primary">Edit</button>
                <button class="btn btn-sm btn-outline-danger">Delete</button>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border rounded-3 p-4 text-center h-100">
            <div class="mb-3"><i class="bi bi-brightness-high fs-2 text-info"></i></div>
            <h5 class="fw-bold">Lunch</h5>
            <div class="text-muted">2 recipes</div>
            <div class="mt-3">
                <button class="btn btn-sm btn-outline-primary">Edit</button>
                <button class="btn btn-sm btn-outline-danger">Delete</button>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border rounded-3 p-4 text-center h-100">
            <div class="mb-3"><i class="bi bi-moon fs-2 text-warning"></i></div>
            <h5 class="fw-bold">Dinner</h5>
            <div class="text-muted">2 recipes</div>
            <div class="mt-3">
                <button class="btn btn-sm btn-outline-primary">Edit</button>
                <button class="btn btn-sm btn-outline-danger">Delete</button>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border rounded-3 p-4 text-center h-100">
            <div class="mb-3"><i class="bi bi-cupcake fs-2 text-purple"></i></div>
            <h5 class="fw-bold">Desserts</h5>
            <div class="text-muted">2 recipes</div>
            <div class="mt-3">
                <button class="btn btn-sm btn-outline-primary">Edit</button>
                <button class="btn btn-sm btn-outline-danger">Delete</button>
            </div>
        </div>
    </div>
</div>