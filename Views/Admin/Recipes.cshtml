@model IEnumerable<RecipeFinder_WebApp.Models.Recipes>
@{
    Layout = "_AdminLayout";
}

<div class="card border-0 shadow-sm rounded-4 p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Manage Recipes</h4>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-warning fw-bold rounded-3 px-4" data-bs-toggle="modal" data-bs-target="#addRecipeModal">
                + Add New Recipe
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>RECIPE NAME</th>
                    <th>CATEGORY</th>
                    <th>COOKING TIME</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-danger">@item.RecipeName</td>
                        <td>
                            <span class="badge rounded-pill bg-info bg-opacity-10 text-info px-3">
                                @(item.Categories?.CategoriesName ?? "General")
                            </span>
                        </td>
                        <td class="text-muted">@item.CookingTime mins</td>
                        <td>
                            <div class="d-flex gap-2">
                                <button class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="addRecipeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">Add New Recipe</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="CreateRecipe" method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Recipe Name *</label>
                        <input type="text" name="RecipeName" class="form-control rounded-3" required>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Category</label>
                            <select name="CategoriesId" class="form-select rounded-3">
                                @foreach (var cat in ViewBag.Categories)
                                {
                                    <option value="@cat.CategoriesId">@cat.CategoriesName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Cooking Time (min)</label>
                            <input type="number" name="CookingTime" class="form-control rounded-3">
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Upload Image</label>
                        <input type="file" name="ImageFile" class="form-control rounded-3">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Instructions</label>
                        <textarea name="Instructions" class="form-control rounded-3" rows="3"></textarea>
                    </div>
                    <div class="text-end">
                        <button type="button" class="btn btn-secondary rounded-3" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning fw-bold rounded-3 px-4">Save Recipe</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>