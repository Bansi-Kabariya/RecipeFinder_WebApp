@model IEnumerable<RecipeFinder_WebApp.Models.Recipes>
@{
    Layout = "_AdminLayout";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white">Recipe Management</h2>
        <a asp-action="CreateRecipe" class="btn btn-warning fw-bold">+ Add New Recipe</a>
    </div>

    <table class="table table-dark table-hover">
        <thead>
            <tr>
                <th>Image</th>
                <th>Recipe Name</th>
                <th>Category</th>
                <th>Time</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><img src="@item.ImagePath" width="50" class="rounded" /></td>
                    <td>@item.RecipeName</td>
                    <td>@item.Categories?.Name</td>
                    <td>@item.CookingTime mins</td>
                    <td>
                        <a class="btn btn-sm btn-info">Edit</a>
                        <a class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>