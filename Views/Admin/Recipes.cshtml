<div class="modal fade" id="addRecipeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-danger">Add New Recipe</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form asp-action="CreateRecipe" asp-controller="Admin" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Recipe Name *</label>
                        <input type="text" name="RecipeName" class="form-control rounded-3" placeholder="e.g., Spaghetti Carbonara" required>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Description *</label>
                        <textarea name="Description" class="form-control rounded-3" rows="2" placeholder="Brief description..." required></textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Category *</label>
                        <div class="d-flex gap-2 flex-wrap mt-2">
                            <label class="btn btn-outline-secondary btn-sm rounded-pill">
                                <input type="radio" name="CategoriesId" value="1" autocomplete="off"> Breakfast
                            </label>
                            <label class="btn btn-outline-secondary btn-sm rounded-pill">
                                <input type="radio" name="CategoriesId" value="2" autocomplete="off"> Lunch
                            </label>
                            <label class="btn btn-outline-secondary btn-sm rounded-pill">
                                <input type="radio" name="CategoriesId" value="3" autocomplete="off"> Dinner
                            </label>
                            <label class="btn btn-outline-secondary btn-sm rounded-pill">
                                <input type="radio" name="CategoriesId" value="4" autocomplete="off"> Desserts
                            </label>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Cooking Time (min)</label>
                            <input type="number" name="CookingTime" class="form-control rounded-3" value="30">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Servings</label>
                            <input type="number" name="Servings" class="form-control rounded-3" value="4">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold">Difficulty</label>
                            <select name="Difficulty" class="form-select rounded-3">
                                <option>Easy</option>
                                <option selected>Medium</option>
                                <option>Hard</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Recipe Image</label>
                        <div class="d-flex align-items-center gap-3">
                            <input type="file" name="ImageFile" class="form-control-file">
                            <small class="text-muted">JPG, PNG (max500KB)</small>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Ingredients *</label>
                        <textarea name="IngredientsList" class="form-control rounded-3" rows="4" placeholder="One per line">500g Pasta
2 Eggs</textarea>
                        <div class="form-text">One per line</div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Steps to Make *</label>
                        <textarea name="Instructions" class="form-control rounded-3" rows="6" placeholder="Step by step instructions...">1. Prepare ingredients.
2. Cook as required.
3. Serve hot.</textarea>
                    </div>

                    <div class="modal-footer border-0 pt-0">
                        <button type="button" class="btn btn-secondary rounded-3" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning fw-bold rounded-3 px-4">+ Add Recipe</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>