@model IEnumerable<RecipeFinder_WebApp.Models.Reviews>
@{
    Layout = "_AdminLayout";
}

<div class="card border-0 shadow-sm rounded-4 p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">User Reviews</h4>
        <span class="badge bg-danger rounded-pill px-3">@Model.Count() Total</span>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th class="border-0">USER</th>
                    <th class="border-0">RECIPE</th>
                    <th class="border-0">RATING</th>
                    <th class="border-0">COMMENT</th>
                    <th class="border-0">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-bold">@item.User?.Username</div>
                            <small class="text-muted">@item.User?.Email</small>
                        </td>
                        <td class="text-danger fw-semibold">
                            @item.Recipe?.RecipeName
                        </td>
                        <td>
                            @for (int i = 0; i < 5; i++)
                            {
                                <i class="bi bi-star-fill @(i < item.Rating ? "text-warning" : "text-muted opacity-25")"></i>
                            }
                        </td>
                        <td class="small text-muted" style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                            @item.Comment
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-danger border-0">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>