@model IEnumerable<RecipeFinder_WebApp.Models.Recipes>
@{
    Layout = "_AdminLayout";
}

<h3 class="fw-bold mb-4">Dashboard Overview</h3>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="d-flex align-items-center">
                <div class="bg-warning rounded-3 p-3 me-3">
                    <i class="bi bi-book fs-3 text-white"></i>
                </div>
                <div>
                    <div class="text-muted small fw-bold">Total Recipes</div>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalRecipes</h2>
                    <small class="text-success">+12 this month</small>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="d-flex align-items-center">
                <div class="bg-danger rounded-3 p-3 me-3" style="background-color: #f85c5c !important;">
                    <i class="bi bi-people fs-3 text-white"></i>
                </div>
                <div>
                    <div class="text-muted small fw-bold">Active Users</div>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalUsers</h2>
                    <small class="text-muted">1 registered users</small>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <div class="d-flex align-items-center">
                <div class="bg-info rounded-3 p-3 me-3 text-white">
                    <i class="bi bi-tags fs-3"></i>
                </div>
                <div>
                    <div class="text-muted small fw-bold">Categories</div>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalCategories</h2>
                    <small class="text-muted">Total categories</small>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 p-4">
    <h5 class="fw-bold mb-4">Recent Activity</h5>

    <div class="list-group list-group-flush">
        <div class="list-group-item border-0 d-flex align-items-center px-0 mb-3">
            <div class="me-3" style="width:46px;">
                <div class="border-start border-4 border-warning h-100 d-flex align-items-center justify-content-center rounded-start"
                    style="height:56px; padding-left:10px;">
                    <div class="bg-warning rounded p-2 text-white">
                        <i class="bi bi-file-earmark-plus"></i>
                    </div>
                </div>
            </div>
            <div>
                <div class="fw-bold">New Recipe Added</div>
                <div class="text-muted small">Manchurian -2 hours ago</div>
            </div>
        </div>

        <div class="list-group-item border-0 d-flex align-items-center px-0 mb-3 bg-light">
            <div class="me-3" style="width:46px;">
                <div class="border-start border-4 border-warning h-100 d-flex align-items-center justify-content-center rounded-start"
                    style="height:56px; padding-left:10px;">
                    <div class="bg-warning rounded p-2 text-white">
                        <i class="bi bi-person-plus"></i>
                    </div>
                </div>
            </div>
            <div>
                <div class="fw-bold">New User Registration</div>
                <div class="text-muted small">Bansi Kabariya joined -18/3/2026</div>
            </div>
        </div>

        <div class="list-group-item border-0 d-flex align-items-center px-0 mb-0">
            <div class="me-3" style="width:46px;">
                <div class="border-start border-4 border-warning h-100 d-flex align-items-center justify-content-center rounded-start"
                    style="height:56px; padding-left:10px;">
                    <div class="bg-warning rounded p-2 text-white">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                </div>
            </div>
            <div>
                <div class="fw-bold">Recipe Updated</div>
                <div class="text-muted small">Bhakhri recipe updated -30 minutes ago</div>
            </div>
        </div>
    </div>
</div>